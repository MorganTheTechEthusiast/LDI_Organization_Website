PORT=5050
JWT_SECRET=change-this-secret-in-production
CLIENT_ORIGIN=http://localhost:5173

# Development database: SQLite
DB_CLIENT=sqlite
SQLITE_PATH=./data/ldi.sqlite

# Production database: PostgreSQL
# In Railway production variables, set:
# DB_CLIENT=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# PGSSL=false

# One-time migration from local SQLite to production PostgreSQL
# CONFIRM_MIGRATE_TO_POSTGRES=true
